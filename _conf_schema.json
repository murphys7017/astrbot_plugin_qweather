{
  "api_host": {
    "type": "string",
    "description": "QWeather API Host",
    "default": "xxx.re.qweatherapi.com"
  },
  "project_id": {
    "type": "string",
    "description": "QWeather Project ID",
    "default": ""
  },
  "credentials_id": {
    "type": "string",
    "description": "QWeather Credentials ID",
    "default": ""
  },
  "private_key_path": {
    "type": "string",
    "description": "Ed25519 private key absolute path on server",
    "default": "/home/aki/key/ed25519-private.pem"
  },
  "private_key_pem": {
    "type": "string",
    "description": "Ed25519 private key content in PEM format. If set, it takes priority over private_key_path",
    "default": ""
  },
  "default_location": {
    "type": "string",
    "description": "Default location when user does not provide one",
    "default": "??"
  },
  "lang": {
    "type": "string",
    "description": "QWeather response language",
    "default": "zh"
  },
  "unit": {
    "type": "string",
    "description": "Temperature unit",
    "default": "m",
    "options": ["m", "i"]
  },
  "warning_local_time": {
    "type": "bool",
    "description": "Whether warning API uses localTime",
    "default": false
  },
  "timeout_seconds": {
    "type": "int",
    "description": "Request timeout seconds",
    "default": 15
  },
  "openmeteo_fallback": {
    "type": "bool",
    "description": "Fallback to Open-Meteo when QWeather now API fails",
    "default": true
  },
  "auto_detect_enabled": {
    "type": "bool",
    "description": "Enable auto weather intent detection",
    "default": true
  },
  "weather_keywords": {
    "type": "list",
    "description": "Keywords for auto weather detection",
    "default": ["??", "??", "??", "??", "??", "??", "weather", "forecast"]
  },
  "debug_log": {
    "type": "bool",
    "description": "Enable verbose debug logs for routing/key loading/API calls",
    "default": false
  }
}
